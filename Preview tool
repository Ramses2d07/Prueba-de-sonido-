<!DOCTYPE html>
<html>
<head>
  <title>Sound Preview Tool</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0d0d0d;
      color: white;

      display: flex;
      flex-direction: column;
      height: 100vh;
    }

    /* 🧭 NAVBAR */
    .navbar {
      background: #111;
      padding: 10px;
      display: flex;
      gap: 10px;
      align-items: center;
    }

    textarea {
      flex: 1;
      height: 80px;
      background: #1e1e1e;
      color: white;
      border: 2px solid #f1c40f;
      border-radius: 8px;
      padding: 10px;
      font-family: monospace;
    }

    button {
      padding: 10px 15px;
      font-weight: bold;

      background: linear-gradient(145deg, #2ecc71, #1e8f4f);
      color: white;

      border: 2px solid #f1c40f;
      border-radius: 8px;

      cursor: pointer;
    }

    .info {
      padding: 10px;
      font-size: 14px;
      color: #aaa;
    }
  </style>
</head>

<body>

  <!-- 🧭 NAVBAR -->
  <div class="navbar">

    <textarea id="code">
// Escribe aquí SOLO frecuencia o función
play(600);
    </textarea>

    <button onclick="runCode()">▶ Play</button>

  </div>

  <div class="info">
    Ejemplo: play(800) | play(300) | play(1000)
  </div>

  <script>
    let ctx;

    function init() {
      if (!ctx) {
        ctx = new (window.AudioContext || window.webkitAudioContext)();
      }
    }

    function play(freq) {
      init();

      const o = ctx.createOscillator();
      const g = ctx.createGain();

      o.connect(g);
      g.connect(ctx.destination);

      o.type = "square";
      o.frequency.value = freq;

      g.gain.value = 0.05;

      o.start();
      o.stop(ctx.currentTime + 0.08);
    }

    function runCode() {
      const code = document.getElementById("code").value;

      try {
        eval(code); // ⚡ ejecuta play(600)
      } catch (e) {
        alert("Error en código");
      }
    }
  </script>

</body>
</html>
